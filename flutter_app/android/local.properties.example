# Copy this file to android/local.properties and fill in your keys.
# DO NOT commit local.properties to source control.

flutter.sdk=/path/to/flutter/sdk
flutter.buildMode=debug
flutter.versionName=1.0.0
flutter.versionCode=1

# Google Maps — restrict to Android apps in the Google Cloud Console
GOOGLE_MAPS_API_KEY=AIzaSy_YOUR_KEY_HERE

# Radar — use a publishable (not secret) key
RADAR_PUBLISHABLE_KEY=prj_live_pk_YOUR_KEY_HERE
